#!/usr/bin/env bash
# Sourced by direnv (or `source .envrc`). Resolves AWS context dynamically.
# Requires: AWS CLI v2 + valid credentials.

export AWS_REGION="${AWS_REGION:-us-east-1}"
export AWS_DEFAULT_REGION="$AWS_REGION"

if command -v aws >/dev/null 2>&1; then
    ACCOUNT_ID="$(aws sts get-caller-identity --query Account --output text 2>/dev/null || true)"
    if [ -n "$ACCOUNT_ID" ] && [ "$ACCOUNT_ID" != "None" ]; then
        export ACCOUNT_ID
        export BUCKET="${BUCKET:-integration-assets-$ACCOUNT_ID}"
    else
        echo "[.envrc] WARNING: aws sts get-caller-identity failed — credentials not configured?" >&2
    fi
else
    echo "[.envrc] WARNING: aws CLI not in PATH" >&2
fi

export ROLE_NAME="${ROLE_NAME:-integration-uploader-role}"
export VIEWER_ROLE_NAME="${VIEWER_ROLE_NAME:-frontend-viewer-role}"
export GROUP_NAME="${GROUP_NAME:-s3-readers}"
export EXTERNAL_ID="${EXTERNAL_ID:-integration-upload-2025}"
export READER_USERS="${READER_USERS:-reader-1 reader-2}"
export ANALYZER_NAME="${ANALYZER_NAME:-account-bucket-analyzer}"

# Origins allowed to call S3 directly via CORS (browser uses temp STS creds).
# Comma-separated. Add the deployed Vercel URL when known.
export FRONTEND_ORIGINS="${FRONTEND_ORIGINS:-http://localhost:3001}"
