PORT=3001
AWS_REGION=us-east-1
BUCKET_NAME=

# Reader-1 credentials (from audit-evidence/reader-keys/reader-1-keys.json)
# Used for read-only operations (viewer role).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Integration role: assumed by the admin user for uploads.
ROLE_ARN=
EXTERNAL_ID=integration-upload-2025

# Admin credentials used to call sts:AssumeRole (set on Vercel).
# Locally, you may leave these empty and rely on AWS_ADMIN_PROFILE below.
ADMIN_AWS_ACCESS_KEY_ID=
ADMIN_AWS_SECRET_ACCESS_KEY=

# Local-only: named profile in ~/.aws/credentials with sts:AssumeRole permission.
# Ignored on Vercel — ADMIN_AWS_* env vars take precedence there.
AWS_ADMIN_PROFILE=default
