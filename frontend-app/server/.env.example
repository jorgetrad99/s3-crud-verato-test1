PORT=3001
AWS_REGION=us-east-1
BUCKET_NAME=

# Roles assumed by the broker on behalf of frontend users.
ROLE_ARN=
VIEWER_ROLE_ARN=
EXTERNAL_ID=integration-upload-2025

# IAM names referenced by the access-list view.
ROLE_NAME=integration-uploader-role
VIEWER_ROLE_NAME=frontend-viewer-role
READERS_GROUP_NAME=s3-readers

# Broker (server-side) credentials. On Vercel set ADMIN_AWS_*; locally
# you may leave empty and use AWS_ADMIN_PROFILE instead.
ADMIN_AWS_ACCESS_KEY_ID=
ADMIN_AWS_SECRET_ACCESS_KEY=
AWS_ADMIN_PROFILE=default

# HMAC secret for the app session token. Stable, random.
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_SECRET=
